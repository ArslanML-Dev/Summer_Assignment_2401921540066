
interface Playable {
    public void play();  
}

class Veena implements Playable {
    public void play() {
        System.out.println("Veena is playing");
    }
}

class Saxophone implements Playable {
    public void play() {
        System.out.println("Saxophone is playing");
    }
}

public class Test {
    public static void main(String[] args) {
        // a. Veena instance
        Veena v = new Veena();
        v.play();

        // b. Saxophone instance
        Saxophone s = new Saxophone();
        s.play();

        // c. Using Playable reference
        Playable p;

        p = v;
        p.play();

        p = s;
        p.play();
    }
}
